    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.62.0",
    "babel-preset-expo": "~12.0.0",
    "expo": "~56.0.12",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
