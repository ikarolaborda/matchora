# ─── MatchOra environment ──────────────────────────────────────────────
# Copy to .env and adjust. The app runs fully on the MOCK provider with NO
# external credentials and NO database — every var below is optional locally.

# Data provider: mock (default) | sportmonks | api-football | sportradar
FOOTBALL_DATA_PROVIDER=mock

# External provider keys (only needed when FOOTBALL_DATA_PROVIDER != mock)
SPORTMONKS_API_KEY=
SPORTRADAR_API_KEY=

# API-Football (api-sports.io) — the implemented real provider.
# Get a free key at https://dashboard.api-football.com (free tier ~100 req/day).
# To enable live real data: set FOOTBALL_DATA_PROVIDER=api-football AND this key.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# League id (World Cup = 1) and season year to pull.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Postgres — OPTIONAL. The mock provider serves data in-memory; the DB is the
# persistence path (db:generate/migrate/seed) and the dockerized stack.
# docker compose value: postgres://matchora:matchora@localhost:5432/matchora
DATABASE_URL=

# Redis/Valkey — OPTIONAL. Live-event fanout/cache for multi-process deploys.
# docker compose value: redis://localhost:6379
REDIS_URL=

# Kafka event bus — OPTIONAL. Empty = in-memory LiveHub (no Kafka needed).
# docker compose host value: localhost:29092 (web container uses kafka:9092).
KAFKA_BROKERS=
KAFKA_CLIENT_ID=matchora
KAFKA_TOPIC=match-events

# ─── Branding (configurable; NO official tournament marks) ───────────────
NEXT_PUBLIC_APP_NAME=MatchOra
NEXT_PUBLIC_TOURNAMENT_LABEL=World Football Tournament 2026
NEXT_PUBLIC_DISCLAIMER=Independent live score application. Not affiliated with, endorsed by, or sponsored by FIFA or any tournament organizer.

# Mobile app → web API base URL (Expo)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── Push notifications (scaffold; see docs/PUSH_NOTIFICATIONS.md) ───────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.matchora.app
APNS_PRIVATE_KEY=
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
